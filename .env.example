TELEGRAM_BOT_TOKEN=
PUBLIC_BASE_URL=https://example.ngrok-free.app
WEBAPP_URL=https://example.ngrok-free.app/webapp/

# Supabase Configuration (AUTENTICACION)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API del backend (build/deploy del frontend, p. ej. Dokploy)
VITE_API_URL=https://api.tu-dominio.com

# App mode: real | simulated
VITE_DATA_MODE=real
SIMULATED_DATA_ENABLED=false

# =============================================================================
# MongoDB Atlas — copiar este bloque a .env en la raíz del repo
# Obtén la URI desde: Atlas → Connect → Drivers → Python
# =============================================================================
MONGODB_URL=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
MONGODB_DB=Arandanos

# =============================================================================
# Docker Compose — opcionales
# =============================================================================
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
# JWT_SECRET=cambiar_por_secreto_largo_y_aleatorio
# AUTH_DEMO_PASSWORD=123456789
#
# Dejar VITE_API_URL vacío en Docker: el frontend usa /api/... y nginx reenvía al backend.
# VITE_API_URL=
